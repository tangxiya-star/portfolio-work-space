{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@expo/vector-icons": [
        "./components/taxpilot/_stubs/expoVectorIcons.tsx"
      ],
      "expo-router": [
        "./components/taxpilot/_stubs/expoRouter.ts"
      ],
      "expo-haptics": [
        "./components/taxpilot/_stubs/expoHaptics.ts"
      ],
      "expo-linear-gradient": [
        "./components/taxpilot/_stubs/expoLinearGradient.tsx"
      ],
      "react-native-safe-area-context": [
        "./components/taxpilot/_stubs/safeAreaContext.tsx"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}